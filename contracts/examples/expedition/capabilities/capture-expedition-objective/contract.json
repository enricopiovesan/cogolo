{
  "kind": "capability_contract",
  "schema_version": "1.0.0",
  "id": "expedition.planning.capture-expedition-objective",
  "namespace": "expedition.planning",
  "name": "capture-expedition-objective",
  "version": "1.0.0",
  "lifecycle": "active",
  "owner": {
    "team": "traverse-core",
    "contact": "enrico.piovesan10@gmail.com"
  },
  "summary": "Capture a structured expedition objective from destination, timing, and planning preference inputs.",
  "description": "Portable capability for normalizing expedition goal details into one governed objective record that downstream planning capabilities can consume without reinterpreting raw intake fields.",
  "inputs": {
    "schema": {
      "type": "object",
      "required": [
        "destination",
        "target_window",
        "preferences",
        "notes"
      ],
      "properties": {
        "destination": {
          "type": "string"
        },
        "target_window": {
          "type": "object",
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "preferences": {
          "type": "object",
          "required": [
            "style",
            "risk_tolerance",
            "priority"
          ],
          "properties": {
            "style": {
              "type": "string"
            },
            "risk_tolerance": {
              "type": "string"
            },
            "priority": {
              "type": "string"
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "outputs": {
    "schema": {
      "type": "object",
      "required": [
        "objective_id",
        "destination",
        "target_window",
        "preferences",
        "notes"
      ],
      "properties": {
        "objective_id": {
          "type": "string"
        },
        "destination": {
          "type": "string"
        },
        "target_window": {
          "type": "object",
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "preferences": {
          "type": "object",
          "required": [
            "style",
            "risk_tolerance",
            "priority"
          ],
          "properties": {
            "style": {
              "type": "string"
            },
            "risk_tolerance": {
              "type": "string"
            },
            "priority": {
              "type": "string"
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "preconditions": [
    {
      "id": "objective-input-provided",
      "description": "Destination, timing, preference, and notes fields are present for intake normalization."
    }
  ],
  "postconditions": [
    {
      "id": "objective-record-normalized",
      "description": "A stable expedition objective record is returned for downstream planning."
    }
  ],
  "side_effects": [
    {
      "kind": "event_emission",
      "description": "Emits the expedition-objective-captured event after normalization succeeds."
    }
  ],
  "emits": [
    {
      "event_id": "expedition.planning.expedition-objective-captured",
      "version": "1.0.0"
    }
  ],
  "consumes": [],
  "permissions": [
    {
      "id": "expedition.plan.capture-objective"
    }
  ],
  "execution": {
    "binary_format": "wasm",
    "entrypoint": {
      "kind": "wasi-command",
      "command": "run"
    },
    "preferred_targets": [
      "local"
    ],
    "constraints": {
      "host_api_access": "none",
      "network_access": "forbidden",
      "filesystem_access": "none"
    }
  },
  "policies": [
    {
      "id": "manual-approval-required"
    }
  ],
  "dependencies": [
    {
      "artifact_type": "event",
      "id": "expedition.planning.expedition-objective-captured",
      "version": "1.0.0"
    }
  ],
  "provenance": {
    "source": "greenfield",
    "author": "enricopiovesan",
    "created_at": "2026-03-27T00:00:00Z",
    "spec_ref": "009-expedition-example-artifacts@1.0.0",
    "adr_refs": [
      "0001-rust-wasm-foundation"
    ],
    "exception_refs": []
  },
  "evidence": [],
  "service_type": "stateless",
  "permitted_targets": [
    "local",
    "cloud",
    "edge",
    "device"
  ],
  "artifact_type": "native"
}
